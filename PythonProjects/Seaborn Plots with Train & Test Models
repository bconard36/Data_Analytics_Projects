import pyodbc
import pandas as pd
import matplotlib.pyplot as plt
%matplotlib inline
import seaborn as sns
import numpy as np
from sklearn.model_selection import train_test_split
from sklearn.linear_model import LinearRegression

# Read CSV data set 
heart = pd.read_csv('Heart_Dataset_UCI_Updated.csv')
heart

heart.info()

# heart['cp_typical_angina'] = heart["cp"].apply(lambda x: 1 if x == 0 else 0)
# heart['cp_atypical_angina'] = heart["cp"].apply(lambda x: 1 if x == 1 else 0)
# heart['cp_non_anginal'] = heart["cp"].apply(lambda x: 1 if x == 2 else 0)
