    <dashboard name='Vehicle Purchase Story' type='storyboard'>
      <style>
        <style-rule element='story-description'>
          <format attr='text-align' id='story-description_9' value='left' />
        </style-rule>
      </style>
      <size maxheight='850' maxwidth='1100' minheight='850' minwidth='1100' preset-index='11' sizing-mode='fixed' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98118' id='1' param='vert' removable='false' type-v2='layout-flow' w='98546' x='727' y='941'>
            <zone h='3882' id='3' type-v2='title' w='98546' x='727' y='941' />
            <zone h='11882' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='98546' x='727' y='4823' />
            <zone h='82354' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='98546' x='727' y='16705'>
              <flipboard active-id='1' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='Intro: Seat Capacity Averages' captured-sheet='Average Seat Count by Manufacturer' id='1' />
                  <story-point caption='Pricing Averages by Manufacturer' captured-sheet='Average Price by Manufacturer' id='2'>
                    <capturedDeltas>
                      <worksheet name='Average Price by Manufacturer'>
                        <shelf-sort-deltas>
                          <shelf-sorts>
                            <shelf-sort-v2 dimension-to-sort='[federated.1t5392g1jkyd2c16veu1m1ohlgeg].[none:ďťżCompany Names:nk]' direction='DESC' is-on-innermost-dimension='true' measure-to-sort-by='[federated.1t5392g1jkyd2c16veu1m1ohlgeg].[avg:Cars Prices:qk]' shelf='rows' />
                          </shelf-sorts>
                        </shelf-sort-deltas>
                      </worksheet>
                    </capturedDeltas>
                  </story-point>
                  <story-point caption='Fuel Types and Average Cost' captured-sheet='Average Price by Manufacturer &amp; Fuel Type' id='3' />
                  <story-point caption='Engine Size, Battery Capacity, and Average Price' captured-sheet='Average Price by Engine Size &amp; Battery Capacity' id='4' />
                  <story-point caption='Fuel Type, Price, and Seating Capacity Comparisons' captured-sheet='Fuel Type Purchase Dashboard' id='5' />
                  <story-point caption='Engine, Battery, and Price Comparisons' captured-sheet='Engine &amp; Battery Purchase Dashboard' id='6' />
                </story-points>
              </flipboard>
            </zone>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='6471' id='6' story-point-id='1' type-v2='text' w='72182' x='12364' y='85059'>
          <formatted-text>
            <run fontalignment='0' fontsize='12'>Most manufacturers average between 5 and 6 seats per vehicle, with Volvo being the lone outlier in overall seating capacity. </run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='6471' hidden='true' id='7' story-point-id='2' type-v2='text' w='67636' x='15818' y='85176'>
          <formatted-text>
            <run fontalignment='0' fontsize='12'>Pricing shows more variation, with most manufacturers averaging between $30,000 and $60,000, while </run>
            <run fontalignment='0' fontsize='12' italic='true'>Tata Motors</run>
            <run fontalignment='0' fontsize='12'> and </run>
            <run fontalignment='0' fontsize='12' italic='true'>Maruti Suzuki</run>
            <run fontalignment='0' fontsize='12'> stand out as clear outliers. </run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='6824' hidden='true' id='8' story-point-id='3' type-v2='text' w='32182' x='67727' y='41882'>
          <formatted-text>
            <run fontalignment='0' fontsize='12'>Fuel type and average vehicle cost, organized by manufacturer and vehicle name. </run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='25294' hidden='true' id='9' story-point-id='4' type-v2='text' w='15273' x='84273' y='28824'>
          <formatted-text>
            <run fontsize='12'>Engine size, battery capacity and average price for each vehicle, broken down by manufacturer and specific model names.  </run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='3059' hidden='true' id='10' story-point-id='5' type-v2='text' w='51636' x='23909' y='15294'>
          <formatted-text>
            <run fontalignment='0' fontsize='12'>Compare price, seating capacity, and fuel type by manufacturer and model. </run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' h='3765' hidden='true' id='11' story-point-id='6' type-v2='text' w='57364' x='18000' y='15176'>
          <formatted-text>
            <run fontalignment='0' fontsize='12'>Compare engine size, battery capacity, and price for each manufacturer and model.</run>
          </formatted-text>
        </zone>
      </zones>
      <simple-id uuid='{D30429D5-1139-4FEB-8B79-C73BAE566CF1}' />
